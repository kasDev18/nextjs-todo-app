# Runtime
NODE_ENV=development
PORT=3000
BASE_URL=http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Database
# Local host runtime:
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nextjs_todo_app
DATABASE_SSL=false

# Optional Docker Compose override. Leave unset unless you want to point the container
# at a different database than the bundled `db` service.
# DOCKER_DATABASE_URL=postgresql://postgres:postgres@db:5432/nextjs_todo_app
# DOCKER_DATABASE_SSL=false

# Optional seed overrides
SEED_USER_EMAIL=sample@email.com
SEED_USER_NAME=Sample User

# Postgres
POSTGRES_DB=nextjs-todo-app
POSTGRES_USER=postgres
POSTGRES_PASSWORD=root

# Better Auth
BETTER_AUTH_SECRET=replace-with-a-long-random-secret


# SMTP (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=sanchezmelith006@gmail.com
SMTP_PASS="yuxd lwmw hcjk aarj"
SMTP_FROM_NAME="Taskflow"
SMTP_FROM_EMAIL=taskflow@gmail.com